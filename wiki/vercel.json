{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "i.tetraslam.world" }],
      "dest": "https://tetrapod.tailc27667.ts.net:10000/zip/$1"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "i.tetraslam.com" }],
      "dest": "https://tetrapod.tailc27667.ts.net:10000/zip/$1"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "link.tetraslam.world" }],
      "dest": "https://tetrapod.tailc27667.ts.net:10000/lnk/$1"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "link.tetraslam.com" }],
      "dest": "https://tetrapod.tailc27667.ts.net:10000/lnk/$1"
    },
    {
      "src": "/kuma-api/(.*)",
      "dest": "https://tetrapod.tailc27667.ts.net:8443/kuma-api/$1"
    },
    { "handle": "filesystem" }
  ]
}
