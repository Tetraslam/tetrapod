#!/bin/bash
set -euo pipefail

if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
  echo "usage: shlink <url> [slug]" >&2
  exit 2
fi

url="$1"
slug="${2:-}"
key="$(sudo sed -n 's/^INITIAL_API_KEY=//p' /opt/tetrapod/shlink.env)"
[ -n "$key" ] || { echo "shlink: API key is missing" >&2; exit 1; }

payload="$(jq -cn --arg url "$url" --arg slug "$slug" \
  '{longUrl:$url} + if $slug == "" then {} else {customSlug:$slug} end')"
response="$(curl -fsS http://127.0.0.1:8085/rest/v3/short-urls \
  -H "X-Api-Key: $key" -H 'Content-Type: application/json' \
  --data-binary "$payload")"

jq -er '.shortUrl' <<<"$response"
