#!/bin/bash
set -euo pipefail

config=/opt/tetrapod/prowlarr/config.xml
ready=false
for _ in {1..30}; do
  if [ -f "$config" ] && curl -fsS http://127.0.0.1:9696/ping >/dev/null; then
    ready=true
    break
  fi
  sleep 2
done
[ "$ready" = true ] || { echo "media-provision: Prowlarr is not ready" >&2; exit 1; }

key="$(xmlstarlet sel -t -v /Config/ApiKey "$config")"
base=http://127.0.0.1:9696/api/v1
api() {
  curl -fsS -H "X-Api-Key: $key" "$@"
}

indexers="$(api "$base/indexer")"
if id="$(jq -er '.[] | select(.name == "1337x") | .id' <<<"$indexers" 2>/dev/null)"; then
  current="$(api "$base/indexer/$id")"
  if [ "$(jq -r '.enable' <<<"$current")" = true ]; then
    jq '.enable = false' <<<"$current" |
      api -X PUT -H 'Content-Type: application/json' --data-binary @- "$base/indexer/$id" >/dev/null
    echo "media-provision: disabled 1337x (AWS IP is blocked upstream)"
  fi
fi

if yts_id="$(jq -er '.[] | select(.name == "YTS") | .id' <<<"$indexers" 2>/dev/null)"; then
  yts="$(api "$base/indexer/$yts_id")"
  if [ "$(jq -r '.enable' <<<"$yts")" != true ]; then
    jq '.enable = true' <<<"$yts" |
      api -X PUT -H 'Content-Type: application/json' --data-binary @- "$base/indexer/$yts_id" >/dev/null
    echo "media-provision: enabled YTS"
  fi
else
  api "$base/indexer/schema" |
    jq '.[] | select(.name == "YTS") | .enable = true | .priority = 25 | .tags = [] | .appProfileId = 1' |
    api -X POST -H 'Content-Type: application/json' --data-binary @- "$base/indexer" >/dev/null
  echo "media-provision: added YTS"
fi
